# -- HTTP --
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# -- Packs --
# Directory containing scenario pack YAML files.
PACKS_DIR=./packs

# -- Cache --
# TTL in ms for in-memory registry index. 0 = reload every request (dev).
REGISTRY_CACHE_TTL_MS=0

# -- Auth --
# Comma-separated API keys. Empty = auth disabled.
AUTH_API_KEYS=

# -- Logging --
LOG_LEVEL=info

# -- Environment --
# Set to "development" for Swagger UI at /docs.
NODE_ENV=development
