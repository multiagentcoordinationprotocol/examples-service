# -- HTTP --
PORT=3000
HOST=0.0.0.0
# Comma-separated origins. Supports wildcards for Vercel preview URLs.
# Examples:
#   CORS_ORIGIN=https://myapp.vercel.app
#   CORS_ORIGIN=https://myapp.vercel.app,https://myapp-*.vercel.app
#   CORS_ORIGIN=*
CORS_ORIGIN=http://localhost:3000

# -- Packs --
PACKS_DIR=./packs

# -- Cache --
REGISTRY_CACHE_TTL_MS=0

# -- Control plane --
CONTROL_PLANE_BASE_URL=http://localhost:3001
CONTROL_PLANE_API_KEY=
CONTROL_PLANE_TIMEOUT_MS=10000
AUTO_BOOTSTRAP_EXAMPLE_AGENTS=true
REGISTER_POLICIES_ON_LAUNCH=true
EXAMPLE_AGENT_PYTHON_PATH=python3
EXAMPLE_AGENT_NODE_PATH=

# -- Direct-agent-auth (RFC-MACP-0004) --
# JSON map {"sender":"bearer-token"} written into each agent's bootstrap as runtime.bearerToken.
# When empty, agents fall back to the legacy HTTP observability path (read-only).
EXAMPLES_SERVICE_AGENT_TOKENS_JSON=
# gRPC endpoint the spawned agents dial directly. Empty = stay on HTTP-only.
MACP_RUNTIME_ADDRESS=
MACP_RUNTIME_TLS=true
# Must be set to `true` when MACP_RUNTIME_TLS=false. Local dev only.
MACP_RUNTIME_ALLOW_INSECURE=false
# Local HTTP listener agents bind so the control-plane can POST cancel requests
# (RFC-MACP-0001 §7.2 Option A). Empty host disables the callback server.
MACP_CANCEL_CALLBACK_HOST=127.0.0.1
MACP_CANCEL_CALLBACK_PORT_BASE=0
MACP_CANCEL_CALLBACK_PATH=/agent/cancel

# -- Auth --
AUTH_API_KEYS=

# -- Logging --
LOG_LEVEL=info

# -- Environment --
NODE_ENV=development
