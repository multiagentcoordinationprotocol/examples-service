{
  "id": "growth-agent",
  "name": "Growth Agent",
  "framework": "langchain",
  "version": "1.0.0",
  "entrypoint": {
    "type": "python_file",
    "value": "agents/langchain_worker/main.py"
  },
  "host": {
    "python": "python3",
    "cwd": ".",
    "env": {
      "PYTHONUNBUFFERED": "1"
    },
    "startupTimeoutMs": 30000
  },
  "macp": {
    "role": "evaluator",
    "supportedMessageTypes": ["Evaluation"],
    "capabilities": ["growth-analysis", "customer-value-assessment"]
  },
  "frameworkConfig": {
    "factory": "build_agent",
    "invokeMode": "invoke",
    "inputMapper": "map_kickoff_to_inputs",
    "outputMapper": "map_result_to_macp_messages"
  }
}
